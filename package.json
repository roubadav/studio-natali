{
  "name": "studio-natali-hono",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:css": "tailwindcss -c tailwind.config.js -i ./src/styles/tailwind.css -o ./public/styles.css --watch",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/styles/tailwind.css -o ./public/styles.css --minify",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute studio-natali-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute studio-natali-db --remote --file=./schema.sql",
    "db:migrate:sms": "wrangler d1 execute studio-natali-db --local --file=./migrations/0002_add_sms_counter.sql",
    "db:migrate:sms:remote": "wrangler d1 execute studio-natali-db --remote --file=./migrations/0002_add_sms_counter.sql",
    "db:seed": "wrangler d1 execute studio-natali-db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute studio-natali-db --remote --file=./seed.sql",
    "screenshots": "npx tsx scripts/screenshots.ts",
    "test:admin": "npx tsx scripts/admin-tests.ts",
    "build:icons": "node scripts/build-icons.cjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "hono": "^4.6.0",
    "lucide-static": "^0.575.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@playwright/test": "^1.58.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
  }
}
